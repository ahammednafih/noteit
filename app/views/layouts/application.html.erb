<!DOCTYPE html>
<html>
<head>
  <title>NoteIt</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="view-transition" content="same-origin">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Stylesheets -->
  <%= stylesheet_link_tag 'bootstrap.min', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'application', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'will-paginate', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'note', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'lexxy', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'nav-bar', 'data-turbo-track': 'reload' %>

  <!-- Google Font Recursive -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Recursive&display=swap" rel="stylesheet">

  <!-- jQuery & Bootstrap Bundle CDN -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://use.fontawesome.com/8ab6cd1b8e.js"></script>

  <!-- Modern Application JS (Turbo, Stimulus) -->
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>

<body class="main-body">
  <%= render 'layouts/nav_bar' %>

  <% if flash[:notice] %>
    <div class="alert alert-success alert-dismissible fade show text-center" role="alert" data-controller="flash">
      <%= flash[:notice] %>
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  <% elsif flash[:alert] %>
    <div class="alert alert-warning alert-dismissible fade show text-center" role="alert" data-controller="flash">
      <strong><%= flash[:alert] %></strong>
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  <% end %>

  <div class="container my-3">
    <%= yield %>
  </div>
</body>
</html>
