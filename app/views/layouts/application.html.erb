<!DOCTYPE html>
<html>
<head>
  <title>NoteIt</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="view-transition" content="same-origin">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <!-- Stylesheets -->
  <%= stylesheet_link_tag 'bootstrap.min', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'application', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'will-paginate', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'note', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'lexxy', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'nav-bar', 'data-turbo-track': 'reload' %>

  <!-- Google Font Recursive -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Recursive&display=swap" rel="stylesheet">

  <!-- jQuery & Bootstrap Bundle CDN -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://use.fontawesome.com/8ab6cd1b8e.js"></script>

  <!-- Modern Application JS (Turbo, Stimulus) -->
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>

<body class="main-body">
  <%= render 'layouts/nav_bar' %>

  <% if flash[:notice] %>
    <div class="alert alert-success alert-dismissible fade show text-center" role="alert" data-controller="flash">
      <%= flash[:notice] %>
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  <% elsif flash[:alert] %>
    <div class="alert alert-warning alert-dismissible fade show text-center" role="alert" data-controller="flash">
      <strong><%= flash[:alert] %></strong>
      <button type="button" class="close" data-dismiss="alert" aria-label="Close">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>
  <% end %>

  <div class="container my-3">
    <%= yield %>
  </div>

  <!-- Turbo Confirmation Modal -->
  <div class="modal fade" id="turbo-confirm-modal" tabindex="-1" role="dialog" aria-labelledby="turboConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
      <div class="modal-content" style="border-radius: 10px; border: none; box-shadow: 0 5px 25px rgba(0,0,0,0.15);">
        <div class="modal-header" style="border-bottom: none; padding: 20px 20px 10px;">
          <h5 class="modal-title" id="turboConfirmModalLabel" style="font-weight: 700;">Confirm Action</h5>
          <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="outline: none;">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body" style="padding: 10px 20px 20px; font-size: 15px;">
          <p id="turbo-confirm-message">Are you sure you want to perform this action?</p>
        </div>
        <div class="modal-footer" style="border-top: none; padding: 10px 20px 20px; display: flex; justify-content: flex-end; gap: 10px;">
          <button type="button" class="btn btn-secondary" data-dismiss="modal" style="border-radius: 6px; padding: 8px 16px; font-weight: 500;">Cancel</button>
          <button type="button" id="turbo-confirm-button" class="btn btn-danger" style="border-radius: 6px; padding: 8px 16px; font-weight: 500;">Confirm</button>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
