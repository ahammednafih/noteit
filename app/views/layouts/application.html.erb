<!DOCTYPE html>
<html class="dark min-h-screen">
  <head>
    <title><%= content_for(:title) || "Noteit" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Noteit">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="bg-slate-950 text-slate-100 font-sans min-h-screen flex flex-col selection:bg-emerald-500 selection:text-slate-950">
    <%= render 'layouts/nav_bar' %>

    <!-- Flash notifications container -->
    <div class="fixed top-20 right-4 z-50 flex flex-col gap-2 max-w-sm w-full">
      <% flash.each do |type, message| %>
        <% 
          bg_class = case type.to_s
                     when 'notice', 'success' then 'bg-emerald-950/90 border-emerald-800 text-emerald-300'
                     when 'alert', 'error' then 'bg-rose-950/90 border-rose-800 text-rose-300'
                     else 'bg-slate-900/90 border-slate-700 text-slate-300'
                     end
        %>
        <div data-controller="flash" 
             class="flex items-center justify-between p-4 rounded-lg border backdrop-blur-sm shadow-lg transform translate-y-0 transition-all duration-300 <%= bg_class %>">
          <div class="flex items-center gap-2">
            <% if type.to_s == 'notice' || type.to_s == 'success' %>
              <svg class="h-5 w-5 text-emerald-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            <% else %>
              <svg class="h-5 w-5 text-rose-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            <% end %>
            <p class="text-sm font-medium"><%= message %></p>
          </div>
          <button data-action="click->flash#dismiss" class="text-slate-400 hover:text-white p-1 rounded transition ml-4 cursor-pointer">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      <% end %>
    </div>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 border-t border-slate-800/50 py-6">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-slate-500">
        &copy; <%= Time.current.year %> NoteIt. Built with Rails 8.0 & Ruby 4.0.4.
      </div>
    </footer>
  </body>
</html>
