<%= form_with url: search_public_notes_notes_path, method: :get, local: true, class: "flex items-center gap-2" do |f| %>
  <%= f.text_field :content, value: params[:content], class: "bg-slate-800 border border-slate-700 text-slate-100 placeholder-slate-400 text-sm rounded-lg focus:ring-emerald-500 focus:border-emerald-500 block w-full p-2.5", placeholder: "Search public notes...", aria: { label: "Search" } %>
  <%= f.submit 'Search', class: "text-white bg-emerald-600 hover:bg-emerald-700 font-medium rounded-lg text-sm px-4 py-2.5 transition duration-150 cursor-pointer" %>
<% end %>
