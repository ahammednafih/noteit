<%= form_with url: search_public_notes_notes_path, method: :get, local: true, class: "form-inline my-2 my-lg-0" do |f| %>
    <%= f.text_field :content, value: params[:content], class: "form-control mr-sm-2", placeholder: "Search", 'aria-label' => "Search" %>
    <%= f.submit 'Search', class: "btn btn-outline-success my-2 my-sm-0" %>
<% end %>
