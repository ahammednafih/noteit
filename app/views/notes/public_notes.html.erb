<% content_for :title, "Noteit | Public Notes" %>
<%= stylesheet_link_tag 'public-notes' %>
<h2 class="text-center">Notes</h2>
<div class="row" id="div-public-notes-index">
    <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12 col-xl-12">
        <div class="card-columns">
            <% @notes.each do |note| %>
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title"><%= note.title %></h4>
                    <p class="card-text"><%= sanitize note.content %></p>
                    <div class="user">
                    <% if note.user.avatar.attached? %>
                        <%= image_tag note.user.avatar.representation(resize_to_limit: [160, 160]), alt: 'profile_image' %>
                    <% else %>
                        <img src="/images/users/avatars/thumb_placeholder-profile-pic.png" alt="profile_image" >
                    <% end %>
                    <div class="user-info">
                        <h5><%= note.user_name %> </h5>
                        <small><%= note.created_at.strftime("%b %d, %Y") %></small>
                    </div>
                    <%= link_to '', show_public_note_note_path(note), :class => 'stretched-link' %>
                    </div>
                </div>
            </div>
            <% end %>
        </div>
    </div>
</div>

<% if @pagy.pages > 1 %>
    <div class="digg_pagination d-flex justify-content-center">
        <%== pagy_bootstrap_nav(@pagy) %>
    </div>
<% end %>
