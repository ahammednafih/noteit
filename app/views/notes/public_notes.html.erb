<% content_for :title, "Public Notes Feed - NoteIt" %>

<div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
  <div>
    <h1 class="text-3xl font-extrabold text-slate-100 tracking-tight">Public Notes</h1>
    <p class="text-slate-400 mt-1 text-sm">Explore notes published and shared by the community.</p>
  </div>
  
  <div class="block sm:hidden">
    <%= render 'layouts/search_form' %>
  </div>
</div>

<% if @notes.present? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @notes.each do |note| %>
      <div class="bg-slate-900 border border-slate-800 hover:border-slate-700 rounded-xl p-6 flex flex-col justify-between shadow-lg hover:shadow-xl transition-all duration-200 group relative">
        <div>
          <!-- Title -->
          <h3 class="text-lg font-bold text-slate-100 group-hover:text-emerald-400 transition mb-3 line-clamp-1">
            <%= note.title %>
          </h3>

          <!-- Snippet -->
          <div class="text-sm text-slate-300 line-clamp-4 mb-4 prose prose-invert max-w-none">
            <%= sanitize note.content %>
          </div>
        </div>

        <!-- Footer: Author & Share -->
        <div class="pt-4 border-t border-slate-800/80 flex items-center justify-between mt-auto">
          <!-- Author Info -->
          <div class="flex items-center gap-2">
            <% if note.user.avatar.attached? %>
              <%= image_tag note.user.avatar.variant(resize_to_limit: [60, 60]), class: "w-7 h-7 rounded-full object-cover border border-slate-800" %>
            <% else %>
              <div class="w-7 h-7 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-[10px] font-bold text-slate-300">
                <%= note.user_name.first.upcase %>
              </div>
            <% end %>
            <div class="flex flex-col">
              <span class="text-xs font-semibold text-slate-300"><%= note.user_name %></span>
              <span class="text-[10px] text-slate-500"><%= note.created_at.strftime("%b %d, %Y") %></span>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex items-center gap-1.5 z-10">
            <!-- Share link -->
            <div data-controller="clipboard" class="relative">
              <input data-clipboard-target="source" type="hidden" value="<%= show_public_note_note_url(note.public_token) %>">
              <button data-action="click->clipboard#copy" data-clipboard-target="button" class="bg-slate-800 hover:bg-slate-700 text-slate-300 p-2 rounded-lg text-xs font-medium transition cursor-pointer" title="Copy shareable link">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.639-2.32m0 0a3 3 0 11.266-1.503l-4.639 2.32m0 0a3 3 0 11-.266 1.503m0 0l4.639 2.32m-.385 1.145a3 3 0 11-.267-1.503l4.639-2.32" />
                </svg>
              </button>
            </div>

            <!-- View note -->
            <%= link_to show_public_note_note_path(note.public_token), class: "bg-slate-800 hover:bg-slate-700 text-slate-300 p-2 rounded-lg transition", title: "Read Full Note" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center mt-8">
      <%= raw pagy_nav(@pagy) %>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-20 bg-slate-900 border border-slate-800 rounded-xl max-w-xl mx-auto px-6">
    <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="h-8 w-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-slate-200">No public notes feed</h3>
    <p class="text-slate-400 mt-1 text-sm max-w-sm mx-auto">No public notes have been published yet.</p>
  </div>
<% end %>
