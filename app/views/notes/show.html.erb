<% content_for :title, "#{@note.title} - NoteIt" %>

<div class="max-w-3xl mx-auto space-y-6">
  <!-- Navigation Header -->
  <div class="flex items-center justify-between">
    <%= link_to notes_path, class: "inline-flex items-center text-sm font-medium text-slate-400 hover:text-white transition" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Notes
    <% end %>

    <div class="flex items-center gap-2">
      <%= link_to edit_note_path(@note), class: "inline-flex items-center justify-center bg-slate-800 hover:bg-slate-700 text-slate-100 font-semibold px-4 py-2 rounded-lg text-sm transition" do %>
        <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
        Edit Note
      <% end %>

      <%= button_to note_path(@note), method: :delete, data: { turbo_confirm: 'Are you sure you want to delete this note?' }, class: "inline-flex items-center justify-center bg-rose-950/40 hover:bg-rose-900/60 border border-rose-800/80 hover:border-rose-700/80 text-rose-300 font-semibold px-4 py-2 rounded-lg text-sm transition cursor-pointer" do %>
        <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
        Delete
      <% end %>
    </div>
  </div>

  <!-- Note Card -->
  <article class="bg-slate-900 border border-slate-800 rounded-xl p-8 shadow-xl space-y-6">
    <!-- Header -->
    <div class="border-b border-slate-800 pb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-100 tracking-tight"><%= @note.title %></h1>
        <p class="text-xs text-slate-500 mt-1">Created on <%= @note.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      </div>

      <div>
        <% if @note.public? %>
          <span class="bg-emerald-950/80 border border-emerald-800 text-emerald-400 text-xs px-3 py-1 rounded-full font-medium">Public Note</span>
        <% else %>
          <span class="bg-slate-800 border border-slate-700 text-slate-400 text-xs px-3 py-1 rounded-full font-medium">Private Note</span>
        <% end %>
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-invert max-w-none text-slate-300 min-h-[150px]">
      <%= sanitize @note.content %>
    </div>

    <!-- Public Sharing Bar (if public) -->
    <% if @note.public? %>
      <div class="pt-6 border-t border-slate-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 bg-slate-950/40 p-4 rounded-lg border border-slate-850">
        <div class="space-y-1">
          <h4 class="text-sm font-semibold text-slate-200">Public Link Sharing</h4>
          <p class="text-xs text-slate-400">Anyone with this link can view this note without logging in.</p>
        </div>

        <div data-controller="clipboard" class="flex items-center gap-2 max-w-full sm:max-w-md w-full">
          <input data-clipboard-target="source" type="text" readonly value="<%= show_public_note_note_url(@note.public_token) %>" class="bg-slate-800 border border-slate-700 text-slate-300 text-xs rounded-lg block w-full p-2.5 focus:outline-none select-all">
          <button data-action="click->clipboard#copy" data-clipboard-target="button" class="bg-slate-700 hover:bg-slate-600 text-slate-100 font-medium rounded-lg text-xs px-4 py-2.5 transition flex items-center gap-1 cursor-pointer flex-shrink-0">
            Copy Link
          </button>
        </div>
      </div>
    <% end %>
  </article>
</div>
