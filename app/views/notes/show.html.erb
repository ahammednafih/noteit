<%= stylesheet_link_tag 'note' %>
<div class="card" id="show-card">
    <h3 id="show-h3" >
        <%= @note.title %>
    </h3>
    <div id="show-div-content">
        <p>
            <%= sanitize @note.content %>
        </p>
        <% if @note.public %>
        <div class="text-center my-3" id="show-div-public" data-controller="clipboard">
            <b>Public URL:</b>
            <input data-clipboard-target="source" type="text" readonly value="<%= show_public_note_note_url(@note) %>" class="form-control d-inline-block w-50 mx-2 text-center" style="background-color: #fff; cursor: text; vertical-align: middle;">
            <button data-action="click->clipboard#copy" data-clipboard-target="button" class="btn btn-dark" style="vertical-align: middle;" title="Copy shareable link">
              <i class="fa fa-share-alt"></i>
            </button>
        </div>
        <% end %>
    </div>
    <div class="note-actions-row" style="padding-bottom: 20px;">
        <%= link_to raw('<i class="fa fa-pencil"></i>'), edit_note_path(@note), class: 'btn btn-dark note-action-btn', title: 'Edit Note' %>
        <%= link_to raw('<i class="fa fa-hand-o-left"></i>'), notes_path, class: 'btn btn-dark note-action-btn', title: 'Back to Notes' %>
        <%= button_to raw('<i class="fa fa-trash-o"></i>'), @note, method: :delete, data: { turbo_confirm: 'Are you sure you want to delete this note?' }, class: 'btn btn-dark note-action-btn', title: 'Delete Note' %>
    </div>
</div>
