<%= stylesheet_link_tag 'note' %>
<div class="card" id="show-card">
    <h3 id="show-h3" >
        <%= @note.title %>
    </h3>
    <div id="show-div-content">
        <p>
            <%= sanitize @note.content %>
        </p>
    </div>
    <div class="note-actions-row" style="padding-bottom: 20px;">
        <%= link_to raw('<i class="fa fa-hand-o-left"></i>'), public_notes_notes_path, class: 'btn btn-dark note-action-btn', title: 'Back to Public Notes' %>
    </div>
</div>
