<% content_for :title, "#{@note.title} - Shared Note" %>

<div class="max-w-3xl mx-auto space-y-6">
  <!-- Navigation Header -->
  <div class="flex items-center justify-between">
    <%= link_to public_notes_notes_path, class: "inline-flex items-center text-sm font-medium text-slate-400 hover:text-white transition" do %>
      <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Public Notes
    <% end %>
  </div>

  <!-- Note Card -->
  <article class="bg-slate-900 border border-slate-800 rounded-xl p-8 shadow-xl space-y-6">
    <!-- Header -->
    <div class="border-b border-slate-800 pb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-slate-100 tracking-tight"><%= @note.title %></h1>
        <p class="text-xs text-slate-500 mt-1">Shared note &bull; Published <%= @note.created_at.strftime("%B %d, %Y") %></p>
      </div>

      <!-- Author -->
      <div class="flex items-center gap-3 bg-slate-950/40 px-4 py-2 rounded-lg border border-slate-850">
        <% if @note.user.avatar.attached? %>
          <%= image_tag @note.user.avatar.variant(resize_to_limit: [80, 80]), class: "w-8 h-8 rounded-full object-cover border border-slate-700" %>
        <% else %>
          <div class="w-8 h-8 rounded-full bg-slate-800 border border-slate-750 flex items-center justify-center text-xs font-bold text-slate-300">
            <%= @note.user.user_name.first.upcase %>
          </div>
        <% end %>
        <div class="flex flex-col">
          <span class="text-xs text-slate-400">Published by</span>
          <span class="text-xs font-semibold text-slate-200"><%= @note.user.user_name %></span>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="prose prose-invert max-w-none text-slate-300 min-h-[150px]">
      <%= sanitize @note.content %>
    </div>
  </article>
</div>
