<% content_for :title, "My Public Notes - NoteIt" %>

<div class="mb-8">
  <h1 class="text-3xl font-extrabold text-slate-100 tracking-tight">My Public Notes</h1>
  <p class="text-slate-400 mt-1 text-sm">These notes are visible to everyone through search and shared URLs.</p>
</div>

<% if @notes.present? %>
  <%= render 'notes_index' %>
<% else %>
  <div class="text-center py-20 bg-slate-900 border border-slate-800 rounded-xl max-w-xl mx-auto px-6">
    <div class="w-16 h-16 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="h-8 w-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.639-2.32m0 0a3 3 0 11.266-1.503l-4.639 2.32m0 0a3 3 0 11-.266 1.503m0 0l4.639 2.32m-.385 1.145a3 3 0 11-.267-1.503l4.639-2.32" />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-slate-200">No public notes</h3>
    <p class="text-slate-400 mt-1 text-sm max-w-sm mx-auto">You don't have any public notes yet. Edit one of your notes and switch on the "Public Note" toggle.</p>
  </div>
<% end %>
