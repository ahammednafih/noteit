<%= stylesheet_link_tag 'sessions' %>
<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |form| %>
<h3 class="text-center">Sign In</h3>
<div class="form-group">
    <%= form.label :email %>
    <%= form.email_field :email, :id => 'email', :class => 'form-control form-control1 input1', :placeholder => 'Enter email', 
                        :required => true, :autofocus => true %>
</div>
<div class="form-group">
    <%= form.label :password %>
    <%= form.password_field :password, :id => 'password', :class => 'form-control form-control1 input1', :placeholder => 'Password', 
                            :required => true %>
    <%= link_to 'Forgot password?', new_password_path(resource_name) %>
</div>
<div>
    <%= form.submit 'Login', :class => 'btn btn-dark btn1' %>
    <div class="text-center"><small>Don't have an account? <%= link_to 'Sign Up', new_registration_path(resource_name) %></small></div>
</div>
<% end %>
