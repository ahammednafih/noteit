<%= stylesheet_link_tag 'sessions' %>
<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |form| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <h3 class="text-center">Sign Up</h3>
  <div class="form-group">
      <%= form.label :user_name %>
      <%= form.text_field :user_name, :id => 'name', :class => 'form-control form-control1 input1', :placeholder => 'Enter your name', 
                          :required => true, :autofocus => true %>
      <small>Only alphabets are allowed</small>
  </div>
  <div class="form-group">
      <%= form.label :email %>
      <%= form.email_field :email, :id => 'email', :class => 'form-control form-control1 input1', :placeholder => 'Enter email', 
                          :required => true %>
      <small>example@example.com</small>
  </div>
  <div class="form-group">
      <%= form.label :password %>
      <%= form.password_field :password, :id => 'password', :class => 'form-control form-control1 input1', :placeholder => 'Password', 
                              :required => true %>
  </div>
  <div class="form-group">
      <%= form.label :password_confirmation, "Confirm Password" %>
      <%= form.password_field :password_confirmation, :id => 'password_confirmation', :class => 'form-control form-control1 input1',
                              :placeholder => 'Confirm Password', :required => true %>
  </div>

  <div>
      <%= form.submit 'Register', :class => 'btn btn-dark btn1' %>
      <div class="text-center"><small>Already have an account? <%= link_to 'Sign In', new_user_session_path %></small></div>
  </div>
<% end %>
